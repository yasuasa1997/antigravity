<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <handlers>
            <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
        </handlers>
        <httpPlatform processPath="powershell.exe"
                      arguments="-ExecutionPolicy Bypass -File &quot;.\run_streamlit.ps1&quot;"
                      stdoutLogEnabled="true"
                      stdoutLogFile=".\logs\streamlit.log"
                      startupTimeLimit="60"
                      processRetries="3">
            <environmentVariables>
                <environmentVariable name="PYTHONPATH" value="." />
                <!-- PORT is provided by HttpPlatformHandler as %HTTP_PLATFORM_PORT% -->
            </environmentVariables>
        </httpPlatform>
        <security>
            <requestFiltering>
                <!-- 大容量の音声ファイルを扱えるように上限を 500MB に設定 (単位: byte) -->
                <requestLimits maxAllowedContentLength="524288000" />
            </requestFiltering>
        </security>
    </system.webServer>
</configuration>
